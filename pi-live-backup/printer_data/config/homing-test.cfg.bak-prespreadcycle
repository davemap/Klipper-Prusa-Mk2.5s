# homing-test.cfg — SENSORLESS HOMING BENCH TEST (NOT for printing)
# =================================================================
# Purpose: validate TMC2209 StallGuard sensorless homing on X and Y so you can decide whether to keep
# the mechanical endstops BEFORE finishing the rebuild. Stripped to just the motion system — NO heaters,
# thermistors, probe, fans or bed, so it boots even with none of that wired yet.
#
# NEEDS: SKR powered (12V, or USB for logic) · X/Y/Z motors INSTALLED in the printer (belts on, carriages
#        move freely by hand) · the X and Y DIAG jumpers fitted on the board.
#
# WHY motors must be installed: sensorless homing triggers on the carriage STALLING against the end of
# travel. A motor free-spinning on the bench never stalls — the test only means something on the real axes.
#
# HOW TO USE (on the Pi):
#   cd ~/printer_data/config
#   cp printer.cfg printer.cfg.real          # back up the real config
#   cp homing-test.cfg printer.cfg           # (this file is deployed alongside the others)
#   # edit [mcu] serial below to match, then in Mainsail: FIRMWARE_RESTART
#   # ...run the tests in scripts/sensorless-endstop-test.md...
#   cp printer.cfg.real printer.cfg          # restore when done, FIRMWARE_RESTART
#
# ONLY run `G28 X` and `G28 Y`. Do NOT run `G28` — Z is a stub here (no PINDA in this test).

[mcu]
# Same path as printer.cfg — fill after flashing: ls /dev/serial/by-id/*
serial: /dev/serial/by-id/REPLACE_WITH_SKR_STM32G0B1_SERIAL

[printer]
kinematics: cartesian
max_velocity: 100
max_accel: 500            # gentle for bench testing
max_z_velocity: 10
max_z_accel: 100

[stepper_x]
step_pin: PB13
dir_pin: !PB12            # if X jogs the wrong way, flip this ! (see test doc)
enable_pin: !PB14
microsteps: 16
rotation_distance: 32
endstop_pin: tmc2209_stepper_x:virtual_endstop
homing_retract_dist: 0
position_endstop: 0
position_min: 0
position_max: 250
homing_speed: 40

[tmc2209 stepper_x]
uart_pin: PC11
tx_pin: PC10
uart_address: 0
run_current: 0.550
interpolate: True
stealthchop_threshold: 999999
diag_pin: ^PC0
driver_SGTHRS: 80         # TUNE: higher = more sensitive (triggers sooner). See test doc.

[stepper_y]
step_pin: PB10
dir_pin: !PB2             # if Y jogs the wrong way, flip this !
enable_pin: !PB11
microsteps: 16
rotation_distance: 32
endstop_pin: tmc2209_stepper_y:virtual_endstop
homing_retract_dist: 0
position_endstop: -2
position_min: -4
position_max: 210
homing_speed: 40

[tmc2209 stepper_y]
uart_pin: PC11
tx_pin: PC10
uart_address: 2
run_current: 0.550
interpolate: True
stealthchop_threshold: 999999
diag_pin: ^PC1
driver_SGTHRS: 80         # TUNE per axis (X and Y often need different values)

# Z is a stub so the config loads — do NOT home Z in this test (it has no real endstop here).
[stepper_z]
step_pin: PB0
dir_pin: PC5
enable_pin: !PB1
microsteps: 16
rotation_distance: 8
endstop_pin: ^PC2         # placeholder (Z-STOP port); never run G28 Z here
position_max: 210
position_min: -2

[tmc2209 stepper_z]
uart_pin: PC11
tx_pin: PC10
uart_address: 1
run_current: 0.550
interpolate: True
stealthchop_threshold: 999999

# Lets you nudge the carriage off the end between homing attempts if a test mis-triggers.
[force_move]
enable_force_move: True
